# .env 

SIM_MODE=true
SP=7.5
DT=5
AUTOTUNE_DURATION=3600   # change to 10800 for real hardware run (3 hours)


#====#TESTING THE HARDWARE#====#
TEST_MODE=false  #TURN OFF TO TURN ON ALL RELAYS (LIGHT, CO2)
USE_AUTOTUNE=true
def onoff_control(ph, setpoint=7.5, tolerance=0.1):
    if ph > setpoint + tolerance:
        return 1   # CO2 ON — pH too high
    else:
        return 0   # CO2 OFF — pH at or below upper threshold


#===TO TEST THE SENSORS SET "TEST_MODE" TO TRUE AND "USE_AUTOTUNE" TO FALSE===#
#===FULL SYSTEM RUN IS "TEST_MODE" TO FALSE AND "USE_AUTOTUNE" TO TRUE===#
